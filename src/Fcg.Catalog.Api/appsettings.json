{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Service": {
    "Name": "CatalogAPI"
  },
  "RabbitMq": {
    "Enabled": false,
    "Host": "localhost",
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest"
  },
  "ConnectionStrings": {
    "CatalogDb": "Data Source=catalog.db"
  },
  "Database": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=catalog.db"
  },
  "Jwt": {
    "Issuer": "fcg-users-api",
    "Audience": "fcg-services",
    "SecretKey": "development-secret-key-change-before-production"
  }
}
